# ── Required on all services ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=docquery

# ── Redis broker ────────────────────────────────────────────────────────────────
# Local:      redis://localhost:6379/0  (docker compose handles this automatically)
# Production: paste your hosted Redis URL here (Upstash, Redis Cloud, etc.)
REDIS_URL=redis://localhost:6379/0

# ── API behaviour ───────────────────────────────────────────────────────────────
IS_PROD=true   # Set true in prod — hides /docs and /redoc

# ── Frontend CORS ───────────────────────────────────────────────────────────────
# Set to the URL of your deployed React frontend so the API allows requests from it
# FRONTEND_URL=https://your-app.vercel.app
