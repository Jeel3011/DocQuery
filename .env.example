# ── Required on all services ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
# Optional (B1): modern tokens are verified locally via the JWKS endpoint using
# SUPABASE_URL alone. Set this ONLY to also verify legacy HS256 tokens
# (Dashboard → Settings → API → JWT Keys → Legacy JWT Secret).
SUPABASE_JWT_SECRET=
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=docquery

# ── Redis broker + semantic cache ───────────────────────────────────────────────
# Local:      redis://localhost:6379/0  (docker compose handles this automatically)
# Production: paste your hosted Redis URL here (Upstash, Redis Cloud, etc.)
# The same Redis instance serves BOTH the Celery broker AND the semantic cache.
REDIS_URL=redis://localhost:6379/0

# ── API behaviour ───────────────────────────────────────────────────────────────
IS_PROD=true   # Set true in prod — hides /docs and /redoc

# ── Frontend CORS ───────────────────────────────────────────────────────────────
# Set to the URL of your deployed React frontend so the API allows requests from it
# FRONTEND_URL=https://your-app.vercel.app

# ── Phase 5: Sentry error tracking (optional) ───────────────────────────────────
# Get a free DSN at https://sentry.io — paste it here to enable error tracking.
# If unset, Sentry is silently disabled (no crash, just no error reporting).
# SENTRY_DSN=https://...@o0.ingest.sentry.io/...

# ── Phase 5: RAGAS evaluation paths (optional) ──────────────────────────────────
# EVAL_QUESTIONS_PATH=eval_questions_v2.json
# EVAL_OUTPUT_PATH=eval_results.json
